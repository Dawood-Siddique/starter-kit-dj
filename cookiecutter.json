{
    "project_name": "DjangoAPI",
    "database": ["sqlite3", "postgresql"],
    "postgres_db_name": "{{ cookiecutter.project_name.replace('-', '_') if cookiecutter.database == 'postgresql' else 'not_used' }}",
    "postgres_user": "{{ 'postgres' if cookiecutter.database == 'postgresql' else 'not_used' }}",
    "postgres_password": "{{ '' if cookiecutter.database == 'postgresql' else 'not_used' }}",
    "postgres_host": "{{ 'localhost' if cookiecutter.database == 'postgresql' else 'not_used' }}",
    "postgres_port": "{{ '5432' if cookiecutter.database == 'postgresql' else 'not_used' }}"
}
